DirectoryIndex index.php
Options -Indexes

<IfModule mod_authz_core.c>
  <FilesMatch "^(config\.php|\.last-sha|\.sync\.lock)$">
    Require all denied
  </FilesMatch>
</IfModule>

<IfModule !mod_authz_core.c>
  <FilesMatch "^(config\.php|\.last-sha|\.sync\.lock)$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>
